[Unit]
Description=Gunicorn instance to serve publishing_lab
After=network.target

[Service]
# User and Group will be replaced by the setup script
User=USER_PLACEHOLDER
Group=USER_PLACEHOLDER
WorkingDirectory=PROJECT_ROOT_PLACEHOLDER
Environment="PATH=PROJECT_ROOT_PLACEHOLDER/venv/bin"
# Using the config file we created
ExecStart=PROJECT_ROOT_PLACEHOLDER/venv/bin/gunicorn -c gunicorn.conf.py server:app

[Install]
WantedBy=multi-user.target
